# Copy to .env and fill in. All variables are loaded from <repo_root>/.env.

# YouTube Data API v3 key — required for scraping/scrape_yt_shorts.py
YOUTUBE_API_KEY=

# Flask session secret for the annotation app — any long random string.
# Without it, sessions are invalidated on every server restart.
SECRET_KEY=

# Shared password all annotators use to log in (defaults to "changeme")
ANNOTATION_PASSWORD=
